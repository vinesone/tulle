{
  "name": "tulle",
  "version": "0.1.0",
  "description": "Shader effects for developers without the need to write GLSL. Tulle is a lightweight library that allows you to apply shader effects to HTML5 canvas and video elements.",
  "type": "module",
  "license": "MIT",
  "author": "Alan Siegler",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinesone/tulle.git"
  },
  "homepage": "https://github.com/vinesone/tulle#readme",
  "bugs": "https://github.com/vinesone/tulle/issues",
  "sideEffects": false,
  "types": "./types/index.d.ts",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./ready": {
      "types": "./types/ready.d.ts",
      "default": "./src/ready.js"
    },
    "./effects": {
      "types": "./types/effects.d.ts",
      "default": "./src/effects/index.js"
    },
    "./effects/*": "./src/effects/*.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "types",
    "guide",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node scripts/serve.mjs",
    "start": "node scripts/serve.mjs",
    "check": "node scripts/check.mjs",
    "test": "node test/pool.test.mjs && node test/composite.test.mjs && node test/transform.test.mjs && node test/effect.test.mjs && node test/text.test.mjs && node test/clip.test.mjs && node test/layout.test.mjs && node test/animate.test.mjs && node test/export.test.mjs && node test/cube.test.mjs",
    "prepublishOnly": "npm run check && npm test"
  },
  "keywords": [
    "webgl",
    "shader",
    "effects",
    "postprocessing",
    "canvas",
    "video",
    "filter",
    "glsl"
  ],
  "engines": {
    "node": ">=22"
  }
}
